# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Programa Beta ---
# Email del administrador con acceso al panel /beta/admin
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=todojuntomirar@gmail.com
# URL pública del sitio (enlaces de referido y emails). Sin barra final.
NEXT_PUBLIC_SITE_URL=https://www.quioba.com
# Gmail SMTP (emails transaccionales de la beta).
# 1. Activa verificación en 2 pasos en la cuenta Gmail
# 2. Ve a: Google Account → Seguridad → Contraseñas de aplicación
# 3. Genera una clave de 16 caracteres y pégala en GMAIL_APP_PASSWORD
# Sin esta clave los emails quedan como 'queued' pero no se envían.
GMAIL_USER=quioba.web@gmail.com
GMAIL_APP_PASSWORD=
