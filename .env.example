# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Programa Beta ---
# Email del administrador con acceso al panel /beta/admin
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=todojuntomirar@gmail.com
# URL pública del sitio (enlaces de referido y emails). Sin barra final.
NEXT_PUBLIC_SITE_URL=https://www.quioba.com
# Resend (emails transaccionales de la beta). Sin esta clave, los emails
# quedan registrados en beta_email_events como 'queued' pero no se envían.
RESEND_API_KEY=
RESEND_FROM=Quioba Beta <beta@quioba.com>
